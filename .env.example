# =============================================================================
# LLM Inference Server Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Backend Selection ---
# Which local backend to use: "ollama" or "vllm"
ACTIVE_BACKEND=ollama
DEFAULT_MODEL=qwen2.5:1.5b

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434

# --- vLLM ---
VLLM_BASE_URL=http://localhost:8001

# --- Token Budget ---
# Maximum total tokens (prompt + completion) allowed per request
MAX_TOKENS_BUDGET=4096

# --- GPU Routing ---
# GPU utilization threshold (0.0-1.0) above which requests route to Azure
GPU_SATURATION_THRESHOLD=0.85
# Max concurrent requests to local backend before routing to Azure
MAX_CONCURRENT_LOCAL=4
# How long (seconds) to cache GPU utilization readings
GPU_UTIL_CACHE_TTL=5.0

# --- Azure OpenAI Fallback (optional) ---
# Leave blank to disable Azure fallback
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Tokenizer ---
# HuggingFace model name for AutoTokenizer (used for local models)
# This should match the model you're running locally
HF_TOKENIZER_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# --- Server ---
HOST=0.0.0.0
PORT=8000
